# Copy to .env and fill in local values.
LITELLM_BASE_URL=https://litellm.example.com
LITELLM_API_KEY=replace-me
LITELLM_STT_MODEL=gpt-4o-transcribe
LITELLM_TRANSCRIPTION_PATH=/v1/audio/transcriptions
LITELLM_RESPONSE_FORMAT=json
# Optional: single ISO 639-1 code such as de or en. Leave empty for mixed dictation.
LITELLM_LANGUAGE=
LITELLM_PROMPT=
REQUEST_TIMEOUT_SECONDS=60
